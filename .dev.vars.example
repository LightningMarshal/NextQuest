# Workers runtime secrets for local dev (`npm run dev` / `npm run preview`).
# Copy to .dev.vars and fill in. In production, set these with
# `wrangler secret put <NAME>` — never commit real values.

# Load .env.development* files when running `wrangler dev`
NEXTJS_ENV=development

# Neon Postgres connection string (pooled HTTP endpoint)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/next_quest?sslmode=require

# Optional, local testing only: route the Neon driver's HTTP transport to a
# local Neon-protocol proxy over plain Postgres (e.g. http://127.0.0.1:4445/sql)
# instead of https://<host>/sql. Leave unset normally; never set in production.
# NEON_HTTP_PROXY_ENDPOINT=

# Better Auth — generate a secret with `npx @better-auth/cli secret`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails that become approved admins on first sign-in
# (first-admin bootstrap — everyone else lands in the approval queue)
ADMIN_EMAILS=

# Optional: Discord webhook for group notifications (new proposals,
# completions, scheduled sessions). Leave empty to disable.
DISCORD_WEBHOOK_URL=

# Shared secret gating /api/cron (called by the worker's scheduled handler,
# see custom-worker.ts). Any random string; leave empty to disable cron tasks.
CRON_SECRET=

# Optional: BGG XML API2 bearer token (boardgamegeek.com/applications/create)
# for board game / TTRPG search and metadata (BGG + RPGGeek share the API).
# Leave empty to disable - tabletop proposals fall back to manual entry.
BGG_API_TOKEN=

# Optional: RAWG API key (rawg.io/apidocs) — a supplemental video-game source
# that fills art/description/genres/release/Metacritic when Steam is missing
# or down. Leave empty to disable; Steam stays the canonical video source.
RAWG_API_KEY=
